# Draft tasks (local, not committed)
aitasks/new/
__pycache__/

# aitask-explain generated data (temporary, per-run)
.aitask-explain/

# PR import intermediate data (temporary, per-run)
.aitask-pr-data/

# History view local state (recently opened tasks)
.aitask-history/

# AgentCrew worktrees (local, per-crew branches)
.aitask-crews/

# Hugo generated files
website/public/
website/resources/
website/node_modules/
website/.hugo_build.lock

# Task data (lives on aitask-data branch, accessed via symlinks)
.aitask-data/
aitasks
aiplans

# Per-profile rendered skill variants (on-demand, not committed)
# Convention: rendered dirs end with a trailing hyphen. Authoring dirs
# never end with a hyphen, so they are safe. See
# .claude/skills/task-workflow/stub-skill-pattern.md for the full design.
.claude/skills/*-/
.agents/skills/*-/
.gemini/skills/*-/
.opencode/skills/*-/

# TODO(t777_29): replace the block below with an auto-generated section managed
# by aitask_regen_gitignore_prerender.sh (scans `headless: true` profiles ×
# `prerender_for_headless: true` skills). For now hardcoded to:
#   pickrem + pickweb (headless skills) × remote profile × 4 agents,
#   plus the task-workflow-remote- closure pickrem/pickweb transitively depend on.
# Pre-rendered headless variants committed so the skill works in Claude Code
# Web where `ait setup` has not run.
# t834: agents with a shared physical root (codex today; +agy in t814) carry
# an extra -<agent>- segment in their rendered-dir name.
!.claude/skills/aitask-pickrem-remote-/
!.agents/skills/aitask-pickrem-remote-codex-/
!.gemini/skills/aitask-pickrem-remote-/
!.opencode/skills/aitask-pickrem-remote-/
!.claude/skills/aitask-pickweb-remote-/
!.agents/skills/aitask-pickweb-remote-codex-/
!.gemini/skills/aitask-pickweb-remote-/
!.opencode/skills/aitask-pickweb-remote-/
!.claude/skills/task-workflow-remote-/
!.agents/skills/task-workflow-remote-codex-/
!.gemini/skills/task-workflow-remote-/
!.opencode/skills/task-workflow-remote-/
