# Draft tasks (local, not committed)
aitasks/new/
__pycache__/

# aitask-explain generated data (temporary, per-run)
.aitask-explain/

# PR import intermediate data (temporary, per-run)
.aitask-pr-data/

# History view local state (recently opened tasks)
.aitask-history/

# AgentCrew worktrees (local, per-crew branches)
.aitask-crews/

# Hugo generated files
website/public/
website/resources/
website/node_modules/
website/.hugo_build.lock

# Task data (lives on aitask-data branch, accessed via symlinks)
.aitask-data/
aitasks
aiplans

# Per-profile rendered skill variants (on-demand, not committed)
# Convention: rendered dirs end with a trailing hyphen. Authoring dirs
# never end with a hyphen, so they are safe. See
# .claude/skills/task-workflow/stub-skill-pattern.md for the full design.
.claude/skills/*-/
.agents/skills/*-/
.gemini/skills/*-/
.opencode/skills/*-/
