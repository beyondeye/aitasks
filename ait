#!/usr/bin/env bash
set -euo pipefail

AIT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$AIT_DIR"  # CRITICAL: ensures TASK_DIR="aitasks" works in all scripts
# shellcheck source=.aitask-scripts/lib/aitask_path.sh
source "$AIT_DIR/.aitask-scripts/lib/aitask_path.sh"

SCRIPTS_DIR="$AIT_DIR/.aitask-scripts"

show_version() {
    local version_file="$AIT_DIR/.aitask-scripts/VERSION"
    if [[ -f "$version_file" ]]; then
        echo "ait version $(cat "$version_file")"
    else
        echo "ait version unknown"
    fi
}

show_usage() {
    cat <<'EOF'
Usage: ait <command> [options]

TUI:
  board          Launch the task board TUI
  codebrowser    Launch the code browser TUI
  diffviewer     Launch the diff viewer TUI
  ide            Start tmux session and launch ait monitor (one-shot IDE startup)
  minimonitor    Compact monitor for tmux agent panes
  monitor        Monitor tmux panes running code agents
  settings       Launch the settings TUI
  syncer         Launch the remote-desync syncer TUI

Task Management:
  create         Create a new task file
  ls             List and prioritize tasks
  update         Update task metadata
  sync           Sync task data with remote (push/pull)
  git            Run git commands against task data (worktree-aware)
  git-health     Diagnose the .aitask-data worktree state
  lock           Lock/unlock tasks to prevent concurrent work

Integration:
  issue-import   Import tasks from GitHub/GitLab issues
  pr-import      Import tasks from GitHub/GitLab pull requests
  issue-update   Update/close linked issues

Reporting:
  stats          Show task completion statistics
  changelog      Generate changelog from commits and plans

Tools:
  codeagent      Manage code agent and model configuration
  explain-runs     Manage aitask-explain run directories
  explain-cleanup  Remove stale aitask-explain run directories
  migrate-archives Convert tar.gz archives to tar.zst / rebucket legacy archives
  zip-old        Archive old completed tasks

AgentCrew:
  crew init      Initialize a new agentcrew
  crew addwork   Add an agent to an existing crew
  crew status    Get/set agent and crew status
  crew command   Send commands to agents
  crew runner    Start/check the crew runner orchestrator
  crew report    Report crew summary, agent details, outputs
  crew cleanup   Remove completed crew worktrees and branches
  crew dashboard TUI dashboard for monitoring and managing crews

Brainstorm:
  brainstorm init      Initialize a brainstorm session for a task
  brainstorm status    Show brainstorm session details
  brainstorm list      List all brainstorm sessions
  brainstorm archive   Finalize and archive a brainstorm session
  brainstorm <num>     Launch brainstorm TUI for a task

Infrastructure:
  setup          Install dependencies
  upgrade        Update aitasks to latest or specific version

Options:
  -h, --help     Show this help message
  -v, --version  Show version

Run 'ait <command> --help' for more information on a command.
EOF
}

# --- Semver comparison: returns 0 if $1 > $2 ---
version_gt() {
    local IFS=.
    # shellcheck disable=SC2206
    local i v1=($1) v2=($2)
    for ((i=0; i<${#v1[@]} || i<${#v2[@]}; i++)); do
        local n1=${v1[i]:-0} n2=${v2[i]:-0}
        if ((n1 > n2)); then return 0; fi
        if ((n1 < n2)); then return 1; fi
    done
    return 1
}

# --- Update check (runs at most once per day) ---
check_for_updates() {
    local cache_file="$HOME/.aitask/update_check"
    local version_file="$AIT_DIR/.aitask-scripts/VERSION"
    local repo="beyondeye/aitasks"
    # Versions are dot-separated non-negative integers (e.g. 0.19.1).
    local version_re='^[0-9]+(\.[0-9]+)*$'

    # Bail if no VERSION file
    [[ -f "$version_file" ]] || return 0

    local local_version
    local_version="$(cat "$version_file")"

    local now
    now="$(date +%s)"

    # Read cache
    local cached_time=0 cached_version=""
    if [[ -f "$cache_file" ]]; then
        read -r cached_time cached_version < "$cache_file" 2>/dev/null || true
    fi

    # Validate cached entries — discard if either field is corrupt. A prior
    # buggy parse could populate cached_version with a raw JSON token and
    # cached_time with a non-numeric string, which would then break the
    # arithmetic and version_gt below.
    [[ "$cached_time" =~ ^[0-9]+$ ]] || cached_time=0
    if [[ -n "$cached_version" && ! "$cached_version" =~ $version_re ]]; then
        rm -f "$cache_file"
        cached_time=0
        cached_version=""
    fi

    # Check if cache is fresh (less than 86400 seconds = 24 hours old)
    local age=$(( now - cached_time ))
    if [[ $age -lt 86400 && -n "$cached_version" ]]; then
        # Cache is fresh — show notice if update available
        if version_gt "$cached_version" "$local_version"; then
            echo -e "\033[1;33m[ait]\033[0m Update available: $local_version → $cached_version"
            echo -e "\033[1;33m[ait]\033[0m Run: ait upgrade latest"
            echo ""
        fi
        return 0
    fi

    # Cache is stale — fetch in background (no message, avoids interleaved output)
    (
        latest_version="$(curl -sS --max-time 5 \
            "https://api.github.com/repos/$repo/releases/latest" 2>/dev/null \
            | grep '"tag_name"' | head -1 \
            | sed 's/.*"tag_name": *"v\?\([^"]*\)".*/\1/')" || true

        mkdir -p "$(dirname "$cache_file")"
        if [[ -n "$latest_version" && "$latest_version" =~ $version_re ]]; then
            echo "$now $latest_version" > "$cache_file"
        else
            # Network failed or parse miss — keep timestamp fresh so we don't
            # retry every invocation, reuse the last known-good version.
            echo "$now ${cached_version:-$local_version}" > "$cache_file"
        fi
    ) &
    disown 2>/dev/null || true
}

# Check for updates (skip for meta-commands, upgrade, and git passthrough)
case "${1:-help}" in
    help|--help|-h|--version|-v|upgrade|setup|git|sync|lock|codeagent|crew|brainstorm|settings|monitor|minimonitor|ide|syncer) ;;
    *) check_for_updates ;;
esac

case "${1:-help}" in
    create)       shift; exec "$SCRIPTS_DIR/aitask_create.sh" "$@" ;;
    ls)           shift; exec "$SCRIPTS_DIR/aitask_ls.sh" "$@" ;;
    update)       shift; exec "$SCRIPTS_DIR/aitask_update.sh" "$@" ;;
    upgrade)      shift; exec "$SCRIPTS_DIR/aitask_upgrade.sh" "$@" ;;
    issue-import) shift; exec "$SCRIPTS_DIR/aitask_issue_import.sh" "$@" ;;
    pr-import)    shift; exec "$SCRIPTS_DIR/aitask_pr_import.sh" "$@" ;;
    board)        shift; exec "$SCRIPTS_DIR/aitask_board.sh" "$@" ;;
    codebrowser)  shift; exec "$SCRIPTS_DIR/aitask_codebrowser.sh" "$@" ;;
    diffviewer)   shift; exec "$SCRIPTS_DIR/aitask_diffviewer.sh" "$@" ;;
    minimonitor)  shift; exec "$SCRIPTS_DIR/aitask_minimonitor.sh" "$@" ;;
    monitor)      shift; exec "$SCRIPTS_DIR/aitask_monitor.sh" "$@" ;;
    ide)          shift; exec "$SCRIPTS_DIR/aitask_ide.sh" "$@" ;;
    settings)     shift; exec "$SCRIPTS_DIR/aitask_settings.sh" "$@" ;;
    syncer)       shift; exec "$SCRIPTS_DIR/aitask_syncer.sh" "$@" ;;
    stats)        shift; exec "$SCRIPTS_DIR/aitask_stats.sh" "$@" ;;
    stats-tui)    shift; exec "$SCRIPTS_DIR/aitask_stats_tui.sh" "$@" ;;
    zip-old)      shift; exec "$SCRIPTS_DIR/aitask_zip_old.sh" "$@" ;;
    issue-update) shift; exec "$SCRIPTS_DIR/aitask_issue_update.sh" "$@" ;;
    setup)        shift; exec "$SCRIPTS_DIR/aitask_setup.sh" "$@" ;;
    changelog)    shift; exec "$SCRIPTS_DIR/aitask_changelog.sh" "$@" ;;
    explain-runs)    shift; exec "$SCRIPTS_DIR/aitask_explain_runs.sh" "$@" ;;
    explain-cleanup) shift; exec "$SCRIPTS_DIR/aitask_explain_cleanup.sh" "$@" ;;
    migrate-archives) shift; exec "$SCRIPTS_DIR/aitask_migrate_archives.sh" "$@" ;;
    lock)         shift; exec "$SCRIPTS_DIR/aitask_lock.sh" "$@" ;;
    sync)         shift; exec "$SCRIPTS_DIR/aitask_sync.sh" "$@" ;;
    codeagent)    shift; exec "$SCRIPTS_DIR/aitask_codeagent.sh" "$@" ;;
    crew)
        shift
        subcmd="${1:-}"
        shift || true
        case "$subcmd" in
            init)      exec "$SCRIPTS_DIR/aitask_crew_init.sh" "$@" ;;
            addwork)   exec "$SCRIPTS_DIR/aitask_crew_addwork.sh" "$@" ;;
            setmode)   exec "$SCRIPTS_DIR/aitask_crew_setmode.sh" "$@" ;;
            status)    exec "$SCRIPTS_DIR/aitask_crew_status.sh" "$@" ;;
            command)   exec "$SCRIPTS_DIR/aitask_crew_command.sh" "$@" ;;
            runner)    exec "$SCRIPTS_DIR/aitask_crew_runner.sh" "$@" ;;
            report)    exec "$SCRIPTS_DIR/aitask_crew_report.sh" "$@" ;;
            cleanup)   exec "$SCRIPTS_DIR/aitask_crew_cleanup.sh" "$@" ;;
            dashboard) exec "$SCRIPTS_DIR/aitask_crew_dashboard.sh" "$@" ;;
            logview)   exec "$SCRIPTS_DIR/aitask_crew_logview.sh" "$@" ;;
            --help|-h|"")
                echo "Usage: ait crew <subcommand> [options]"
                echo ""
                echo "Available subcommands:"
                echo "  init        Initialize a new agentcrew"
                echo "  addwork     Add an agent to an existing crew"
                echo "  setmode     Change launch_mode of a Waiting agent (headless|interactive)"
                echo "  status      Get/set agent and crew status"
                echo "  command     Send commands to agents"
                echo "  runner      Start/check the crew runner orchestrator"
                echo "  report      Report crew summary, agent details, outputs"
                echo "  cleanup     Remove completed crew worktrees and branches"
                echo "  dashboard   TUI dashboard for monitoring and managing crews"
                echo "  logview     ANSI-aware agent log viewer TUI"
                echo ""
                echo "Run 'ait crew <subcommand> --help' for subcommand-specific help."
                exit 0
                ;;
            *)         echo "ait crew: unknown subcommand '$subcmd'" >&2; echo "Available: init, addwork, setmode, status, command, runner, report, cleanup, dashboard, logview" >&2; exit 1 ;;
        esac
        ;;
    brainstorm)
        shift
        subcmd="${1:-}"
        shift || true
        case "$subcmd" in
            init)              exec "$SCRIPTS_DIR/aitask_brainstorm_init.sh" "$@" ;;
            status)            exec "$SCRIPTS_DIR/aitask_brainstorm_status.sh" "$@" ;;
            archive)           exec "$SCRIPTS_DIR/aitask_brainstorm_archive.sh" "$@" ;;
            apply-initializer) exec "$SCRIPTS_DIR/aitask_brainstorm_apply_initializer.sh" "$@" ;;
            delete)            exec "$SCRIPTS_DIR/aitask_brainstorm_delete.sh" "$@" ;;
            list)              exec "$SCRIPTS_DIR/aitask_brainstorm_status.sh" --list "$@" ;;
            [0-9]*)            exec "$SCRIPTS_DIR/aitask_brainstorm_tui.sh" "$subcmd" "$@" ;;
            --help|-h|"")
                echo "Usage: ait brainstorm <subcommand> [options]"
                echo ""
                echo "Available subcommands:"
                echo "  init               Initialize a brainstorm session for a task"
                echo "  status             Show brainstorm session details"
                echo "  list               List all brainstorm sessions"
                echo "  archive            Finalize and archive a brainstorm session"
                echo "  apply-initializer  Re-run apply on a session (recovers stuck imports)"
                echo "  delete             Completely delete a brainstorm session"
                echo "  <num>              Launch brainstorm TUI for a task"
                echo ""
                echo "Run 'ait brainstorm <subcommand> --help' for subcommand-specific help."
                exit 0
                ;;
            *)  echo "ait brainstorm: unknown subcommand '$subcmd'" >&2; echo "Available: init, status, list, archive, apply-initializer, delete" >&2; exit 1 ;;
        esac
        ;;
    git)          shift; source "$SCRIPTS_DIR/lib/task_utils.sh"
                  if [[ "${1:-}" == "push" ]]; then
                      task_push
                  else
                      task_git "$@"
                  fi
                  ;;
    git-health)   shift; source "$SCRIPTS_DIR/lib/task_utils.sh"
                  task_git_health "$@"
                  ;;
    help|--help|-h) show_usage ;;
    --version|-v)   show_version ;;
    *)
        echo "ait: unknown command '$1'" >&2
        echo "Run 'ait help' for usage information." >&2
        exit 1
        ;;
esac
